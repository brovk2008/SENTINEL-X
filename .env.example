# ============================================================
# SafetyOS Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ---- LLM PROVIDERS (configure at least one) ----
# Google Gemini (free tier - recommended default)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter (alternative - access many models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default LLM provider: gemini | openrouter | anthropic | ollama
DEFAULT_LLM_PROVIDER=gemini

# Default model per provider
GEMINI_DEFAULT_MODEL=gemini-2.0-flash-exp
OPENROUTER_DEFAULT_MODEL=google/gemini-flash-1.5
ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-20241022
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# ---- DATABASE ----
POSTGRES_DB=safetyos
POSTGRES_USER=safetyos
POSTGRES_PASSWORD=safetyos_secure_pwd_2025
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://safetyos:safetyos_secure_pwd_2025@postgres:5432/safetyos

# ---- REDIS ----
REDIS_URL=redis://redis:6379

# ---- NEO4J ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=safetyos_neo4j_pwd
NEO4J_AUTH=neo4j/safetyos_neo4j_pwd

# ---- CHROMADB ----
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ---- MQTT ----
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=safetyos

# ---- FIREBASE (optional - for real push notifications) ----
# Leave blank to use in-app simulation mode
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---- TWILIO (optional - for SMS alerts) ----
# Leave blank to use in-app simulation mode
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- APP CONFIG ----
APP_ENV=development
SECRET_KEY=safetyos-super-secret-key-change-in-prod
CORS_ORIGINS=http://localhost:3000,http://frontend:3000,http://localhost

# ---- PLANT CONFIG ----
PLANT_NAME=Bharat Petrochemicals Refinery Unit 3
PLANT_LOCATION=Vishakhapatnam, Andhra Pradesh

# ---- NEXT.JS (frontend) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=SafetyOS
